# Get a key from https://developer.tech.yandex.ru/ (JavaScript API)
# If you get "Invalid API key", edit the key and add to HTTP Referer restrictions:
#   http://localhost
#   http://127.0.0.1
VITE_YANDEX_API_KEY=your_key_here

# Optional: proxy for routing (avoids CORB on GitHub Pages). Deploy api/route.js to Vercel, set YANDEX_API_KEY there, then set:
# VITE_ROUTER_PROXY_URL=https://your-app.vercel.app/api/route